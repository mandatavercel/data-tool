# Streamlit secrets — 민감한 정보 저장용
#
# 이 파일을 secrets.toml 로 이름 바꾸고(.example 떼고) 발급받은 인증키를 넣으세요.
# .streamlit/secrets.toml 은 streamlit 이 자동으로 읽어 st.secrets["KEY_NAME"] 으로 접근 가능.
#
# ⚠️ secrets.toml 은 git 에 커밋하지 마세요. (.gitignore 에 추가 권장)

# KRX Open API 인증키 (https://openapi.krx.co.kr 에서 발급)
KRX_AUTH_KEY = "여기에_발급받은_KRX_인증키_붙여넣기"

# DART Open API 인증키 (https://opendart.fss.or.kr 에서 발급)
DART_API_KEY = "여기에_발급받은_DART_인증키_붙여넣기"
