# ════════════════════════════════════════════════════════════════════════
# .gitignore — Alt-Data Intelligence Platform
# 민감 파일·로컬 캐시·빌드 산출물 git 추적 제외
# ════════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── IDE ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Streamlit secrets (API keys 등 — 절대 commit 금지!) ─────────────────
**/.streamlit/secrets.toml

# ── 분석앱 영구 저장 (홈 디렉토리에 저장되지만 만약 프로젝트로 들어오면 제외) ─
*.local_secrets.json
config.local.json

# ── 사용자 데이터 (POS·매출 등 절대 commit 금지) ─────────────────────────
*.xlsx
*.xls
*.csv
*.parquet
*.feather

# ── 분석 결과 출력 ───────────────────────────────────────────────────────
exports/
output/
*.pptx
*.pdf

# ── 캐시 ─────────────────────────────────────────────────────────────────
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── 로그 ─────────────────────────────────────────────────────────────────
*.log
logs/

# ── 임시 백업 ────────────────────────────────────────────────────────────
*.bak
*.orig
*.rej

# ── Jupyter ──────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── macOS ────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# ── OS / 기타 ────────────────────────────────────────────────────────────
Thumbs.db
desktop.ini
