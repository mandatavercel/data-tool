# ════════════════════════════════════════════════════════════════════════
# Streamlit Secrets — Mandata Data Intelligence
#
# 사용법:
#   로컬: 이 파일을 같은 폴더의 `secrets.toml`로 복사 후 키 채우기 (gitignore됨)
#   Cloud: Streamlit Cloud → App settings → Secrets에 같은 내용 붙여넣기
#
# ⚠️ 이 example 파일은 commit OK · 실제 secrets.toml은 절대 commit 금지!
# ════════════════════════════════════════════════════════════════════════

# ── DART API Key (선택) ─────────────────────────────────────────
# https://opendart.fss.or.kr 무료 발급
# 데이터분석 앱의 Earnings Intelligence, Factor Research에 사용
DART_API_KEY = "여기에_DART_API_키"

# ── Anthropic API Key (선택) ────────────────────────────────────
# https://console.anthropic.com 발급
# 사업자조회의 '영문코드 → 한글명' 모드, 데이터 카탈로그 영문화에 사용
# (사용자가 각자 사이드바에 직접 입력할 수도 있어서 필수 아님)
ANTHROPIC_API_KEY = "sk-ant-..."

# ── 공공데이터포털 NTS API Key (선택) ──────────────────────────
# https://data.go.kr — "국세청_사업자등록정보 진위확인 및 상태조회" 신청
# 사업자조회 앱의 국세청 사업자상태 조회에 사용
NTS_API_KEY = "여기에_NTS_API_키"

# ════════════════════════════════════════════════════════════════════════
# 권한(ACL) 관리는 secrets가 아닌 acl.json 으로!
#   - 위치: 프로젝트 루트의 acl.json
#   - 편집: 통합 런처 → 🛡 관리자 페이지 → 편집 → Export → GitHub commit
#   - Streamlit Cloud는 GitHub 변경 감지 시 자동 재배포 → 변경사항 영구 반영
# ════════════════════════════════════════════════════════════════════════
